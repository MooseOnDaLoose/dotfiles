# Read more about SSH config files: https://linux.die.net/man/5/ssh_config

# Include all files in the config.d directory
Include config.d/* 

############# HOSTS #############

Host <Friendly Name>
    HostName <Host_Name_or_IP>
    User <username>
    IdentityFile <path_to_private_key>
    Port <port_number>
    # Additional options can be added here, such as:
    # ForwardAgent yes
    # ProxyJump <jump_host>
